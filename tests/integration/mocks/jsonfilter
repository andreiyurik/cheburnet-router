#!/usr/bin/env python3
"""mock jsonfilter — реализует подмножество синтаксиса нужное rpcd-cheburnet.

Поддерживаемые формы выражений (-e EXPR):
   @.field                          — простое поле
   @.field.subfield                 — вложенные поля
   @["field-with-dash"]             — bracket-notation для ключей с тире
                                       (нужно для @["ipv4-address"] в net_detect_lan_conflict)
   @["a"][0].b                      — индексация массива
   @.foo[0]                         — индексация массива в dot-notation

Это надмножество того, что было раньше — обратно совместимо со всеми существующими
вызовами `jf '@.field'`, плюс новый детектор LAN-conflict умеет добраться
до `ipv4-address[0].address` в выводе ubus.
"""
import json
import re
import sys


def parse_path(path):
    """Разбирает выражение в список ключей/индексов.

    Примеры:
        '@.foo.bar'              → ['foo', 'bar']
        '@["ipv4-address"][0].x' → ['ipv4-address', 0, 'x']
        '@.foo[0]'               → ['foo', 0]
    """
    s = path.lstrip("@")
    tokens = []
    # Regex захватывает три варианта токена: ["..."], [N], либо .name
    # Используем lookahead чтобы не было overlap'ов.
    pattern = re.compile(r'\["([^"]+)"\]|\[(\d+)\]|\.([A-Za-z_][\w-]*)')
    pos = 0
    while pos < len(s):
        m = pattern.match(s, pos)
        if not m:
            # Допускаем висящие точки в начале или мусор в конце — просто стоп.
            break
        if m.group(1) is not None:        # ["key"]
            tokens.append(m.group(1))
        elif m.group(2) is not None:      # [N]
            tokens.append(int(m.group(2)))
        else:                              # .name
            tokens.append(m.group(3))
        pos = m.end()
    return tokens


def get_path(data, path):
    tokens = parse_path(path)
    for t in tokens:
        if isinstance(t, int):
            if isinstance(data, list) and 0 <= t < len(data):
                data = data[t]
            else:
                return None
        else:
            if isinstance(data, dict) and t in data:
                data = data[t]
            else:
                return None
    return data


args = sys.argv[1:]
expr = None
i = 0
while i < len(args):
    if args[i] == "-e":
        expr = args[i + 1]
        i += 2
        continue
    if args[i].startswith("-"):
        i += 1
        continue
    i += 1

if expr is None:
    sys.exit(0)

try:
    raw = sys.stdin.read()
    data = json.loads(raw) if raw.strip() else {}
except Exception:
    sys.exit(1)

result = get_path(data, expr)
if result is None:
    sys.exit(0)  # пустой stdout — стандартное поведение jsonfilter

if isinstance(result, bool):
    print("true" if result else "false")
elif isinstance(result, (dict, list)):
    print(json.dumps(result))
else:
    print(result)
