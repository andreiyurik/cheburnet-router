#!/usr/bin/env bash
# mock uci — минимальная реализация для нужд rpcd-cheburnet.
# Хранит «UCI-state» в $FAKE_ROOT/uci-state (key=value, по строке).
# Поддерживает: get, set, -q get, commit (no-op), show (для grep'а),
# add_list (no-op), delete (no-op).

echo "$@" >> "${CALLS_DIR:-/tmp}/uci"

STATE="${FAKE_ROOT:?FAKE_ROOT not set}/uci-state"
touch "$STATE"

# Парсим -q (quiet — игнорируем, всегда тихо)
QUIET=0
while [ "$1" = "-q" ]; do
    QUIET=1
    shift
done

cmd="$1"; shift

case "$cmd" in
    get)
        key="$1"
        # Раньше тут было `$1=""; sub(/^=/,""); print` — awk при $1="" пересобирает
        # $0 c OFS=" ", и значение печаталось с ведущим пробелом
        # (uci-set'нутый "192.168.1.1/24" → " 192.168.1.1/24"). В реальном
        # uci такого нет, и net_lan_ip / parser'ы в проде падали бы.
        # Берём substring после первого "=" — POSIX parameter expansion,
        # никаких сюрпризов с separator'ами.
        val="$(grep -m1 "^${key}=" "$STATE" 2>/dev/null)"
        if [ -n "$val" ]; then
            printf '%s\n' "${val#*=}"
            exit 0
        fi
        # default-ы для известных ключей
        case "$key" in
            network.lan.ipaddr) echo "192.168.1.1"; exit 0 ;;
            wireless.default_radio0.ssid) echo ""; exit 0 ;;
        esac
        [ "$QUIET" = "1" ] && exit 1
        echo "uci: Entry not found" >&2
        exit 1
        ;;
    set)
        # foo.bar.baz=value
        kv="$1"
        key="${kv%%=*}"
        val="${kv#*=}"
        # remove existing
        grep -v "^${key}=" "$STATE" > "${STATE}.new" 2>/dev/null || true
        mv "${STATE}.new" "$STATE"
        printf '%s=%s\n' "$key" "$val" >> "$STATE"
        ;;
    add_list|add|delete|commit|reorder|rename)
        : # no-op для теста
        ;;
    show)
        # Используется в setup/install.sh для grep'а Block-SSH-from-WAN.
        # Ничего не печатаем — пусть grep вернёт false, мок-флоу простой.
        :
        ;;
    *)
        # неизвестный — тихо OK
        :
        ;;
esac
exit 0
