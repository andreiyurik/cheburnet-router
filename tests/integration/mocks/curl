#!/usr/bin/env bash
# mock curl — для integration-тестов healthcheck'а через Clash API sing-box'а.
#
# По умолчанию: для URL содержащих /rules возвращает fake-response,
# где упомянут exclude_ru-russia_outside-community-ruleset (т.е. rule_set
# подхвачен sing-box'ом). Для остальных URL — пустой ответ + exit 0.
#
# Тест может переопределить ответ /rules через $FAKE_ROOT/clash-rules-response:
#   • файл не существует → дефолтный JSON с russia_outside (loaded=true)
#   • файл существует → его содержимое возвращается как тело ответа
#   • файл содержит "MOCK_NO_API" → имитируем фейл curl (sing-box API недоступен)
echo "$@" >> "${CALLS_DIR:-/tmp}/curl"

# Собираем URL из аргументов (последний non-option arg). curl зовётся как
# `curl -sf --max-time 3 "http://192.168.1.1:9090/rules"` — нам важен path.
_url=""
for _a in "$@"; do
    case "$_a" in
        http://*|https://*) _url="$_a" ;;
    esac
done

case "$_url" in
    *"/rules"*)
        _resp_file="${FAKE_ROOT:?}/clash-rules-response"
        if [ -f "$_resp_file" ]; then
            if grep -q "MOCK_NO_API" "$_resp_file"; then
                # Симулируем отсутствие sing-box API: curl --max-time выходит
                # с rc=28 (operation timeout) и не печатает body.
                exit 28
            fi
            cat "$_resp_file"
        else
            # Дефолт: rule_set с russia_outside в payload, как реальный sing-box
            # его возвращает (см. /rules endpoint /providers/rules).
            printf '%s' '{"rules":[{"type":"default","payload":"inbound=tproxy-in rule_set=[exclude_ru-russia_outside-community-ruleset exclude_ru-user-domains-ruleset]","proxy":"route(direct-out)"}]}'
        fi
        exit 0
        ;;
    *)
        # Для всех остальных URL — пустой ответ. Тесты не должны зависеть.
        exit 0
        ;;
esac
