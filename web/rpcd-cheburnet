#!/bin/sh
# rpcd-cheburnet — ubus-RPC handler для веб-мастера cheburnet-router.
# Ставится в /usr/libexec/rpcd/cheburnet и автоматически подхватывается rpcd.
#
# Методы:
#   get_status         — состояние системы (режим, установлен ли VPN, handshake AWG, running-сервисы)
#   install_start      — запустить установку (ssid, wifi_key, country, awg_conf, root_pass)
#   install_progress   — текущий шаг + последние 5000 байт логов + done-флаг
#   install_cancel     — пометить установку как отменённую (реально не убивает процесс)
#   mode_switch        — переключить HOME/TRAVEL
#   service_restart    — перезапустить сервис (vpn | dns | adblock)
#   replace_awg_conf   — заменить awg0.conf после установки (с auto-rollback при сбое)
#
# Протокол rpcd: скрипт вызывается с аргументами `list` или `call <method>`.
# В режиме `call` аргументы метода читаются из stdin как JSON.

INSTALL_DIR="${INSTALL_DIR:-/opt/cheburnet}"
STATE_DIR="${STATE_DIR:-/tmp/cheburnet}"
LOG_FILE="$STATE_DIR/install.log"
STATE_FILE="$STATE_DIR/state"
DONE_FILE="$STATE_DIR/done"
PID_FILE="$STATE_DIR/pid"

# Системные пути роутера. По умолчанию — стандартные OpenWrt-локации;
# integration-тесты переопределяют их через env, чтобы запустить скрипт в
# sandbox без реального /etc /usr и /etc/init.d.
ETC_CHEBURNET="${ETC_CHEBURNET:-/etc/cheburnet}"
ETC_AWG_DIR="${ETC_AWG_DIR:-/etc/amnezia/amneziawg}"
ETC_ADBLOCK_CFG="${ETC_ADBLOCK_CFG:-/etc/adblock-lean/config}"
ETC_INIT_D="${ETC_INIT_D:-/etc/init.d}"
USR_BIN_VPN_MODE="${USR_BIN_VPN_MODE:-/usr/bin/vpn-mode}"

mkdir -p "$STATE_DIR"

# === Подключаем общие pure-функции (json_escape, валидаторы) ===
# Файл ставится bootstrap.sh в /opt/cheburnet/lib/. Fallback на относительный
# путь — для запуска из репо-чекаута (тесты, отладка).
LIB="${CHEBURNET_LIB:-$INSTALL_DIR/lib/cheburnet-utils.sh}"
[ -f "$LIB" ] || LIB="$(dirname "$0")/../../../opt/cheburnet/lib/cheburnet-utils.sh"
# shellcheck source=../lib/cheburnet-utils.sh disable=SC1090,SC1091
. "$LIB"

# net-detect: net_lan_ip с CIDR-стрипом (используется в DNS probe для get_status)
NET_LIB="${CHEBURNET_NET_LIB:-$INSTALL_DIR/lib/net-detect.sh}"
[ -f "$NET_LIB" ] || NET_LIB="$(dirname "$0")/../../../opt/cheburnet/lib/net-detect.sh"
# shellcheck source=../lib/net-detect.sh disable=SC1090,SC1091
. "$NET_LIB"

# family-filter: on/off/status управление Hagezi NSFW в raw_block_lists
FAMILY_LIB="${CHEBURNET_FAMILY_LIB:-$INSTALL_DIR/lib/family-filter.sh}"
[ -f "$FAMILY_LIB" ] || FAMILY_LIB="$(dirname "$0")/../../../opt/cheburnet/lib/family-filter.sh"
# shellcheck source=../lib/family-filter.sh disable=SC1090,SC1091
. "$FAMILY_LIB"

# podkop-config: podkop_current_mode читает HOME/TRAVEL из UCI подkop'а.
PODKOP_LIB="${CHEBURNET_PODKOP_LIB:-$INSTALL_DIR/lib/podkop-config.sh}"
[ -f "$PODKOP_LIB" ] || PODKOP_LIB="$(dirname "$0")/../../../opt/cheburnet/lib/podkop-config.sh"
# shellcheck source=../lib/podkop-config.sh disable=SC1090,SC1091
. "$PODKOP_LIB"

# Перезагрузка adblock-lean blocklist'а через restart dnsmasq.
# Используется set_blocklist_tier и set_family_filter — оба меняют
# /etc/adblock-lean/config и должны триггерить пересчёт.
_reload_blocklist() {
    "$ETC_INIT_D/adblock-lean" start >/dev/null 2>&1
    "$ETC_INIT_D/dnsmasq" restart >/dev/null 2>&1
}

# === list: описание доступных методов ===
if [ "$1" = "list" ]; then
    cat <<'EOF'
{
    "get_status": {},
    "install_start": {
        "ssid": "str",
        "wifi_key": "str",
        "country": "str",
        "awg_conf": "str",
        "root_pass": "str",
        "token": "str"
    },
    "install_progress": {},
    "install_cancel": {},
    "mode_switch": { "mode": "str" },
    "service_restart": { "service": "str" },
    "set_blocklist_tier": { "tier": "str" },
    "set_family_filter": { "enabled": "bool" },
    "factory_reset": { "confirm": "str" },
    "replace_awg_conf": { "awg_conf": "str" }
}
EOF
    exit 0
fi

# === call: вызов метода ===
if [ "$1" != "call" ]; then
    echo '{"error":"unknown action"}' >&2
    exit 1
fi

METHOD="$2"
INPUT=$(cat)

# jsonfilter helper — возвращает пустую строку при отсутствии поля
jf() {
    echo "$INPUT" | jsonfilter -e "$1" 2>/dev/null || true
}

case "$METHOD" in

    # ------------------------------------------------------------------
    get_status)
        MODE=$(podkop_current_mode)

        # Определяем тип установки
        INSTALL_TYPE="none"
        if [ -f "$ETC_AWG_DIR/awg0.conf" ] && [ -x "$ETC_INIT_D/podkop" ]; then
            INSTALL_TYPE="vpn"
        fi

        # Установка в процессе?
        INSTALLING="false"
        [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null && INSTALLING="true"

        # adblock-lean — НЕ демон, а одноразовый job: запустился, скачал
        # блок-лист, сконфигурировал dnsmasq, вышел. У него нет pidfile,
        # и `service status` на разных версиях init-скрипта возвращает
        # разное (от 'running' до пустоты). Поэтому проверяем артефакт —
        # сжатый блок-лист, который 03-adblock.sh же и валидирует.
        ADBLOCK_UP="false"
        [ -s /var/run/adblock-lean/abl-blocklist.gz ] && ADBLOCK_UP="true"

        PODKOP_UP="false"
        "$ETC_INIT_D/sing-box" status 2>&1 | grep -qi running && PODKOP_UP="true"

        # DNS — отдельный probe: dnsmasq running + резолвится тестовый домен
        # Лейбл «DNS (DoH)» в UI описывает работу sing-box-DoH через dnsmasq;
        # podkop_up недостаточен — dnsmasq может упасть отдельно.
        DNS_UP="false"
        if "$ETC_INIT_D/dnsmasq" status 2>&1 | grep -qi running; then
            LAN_IP=$(net_lan_ip 127.0.0.1)
            if nslookup cloudflare.com "$LAN_IP" 2>/dev/null | grep -q Address; then
                DNS_UP="true"
            fi
        fi

        # AWG handshake age
        AWG_HS_AGE="null"
        HS=$(awg show awg0 latest-handshakes 2>/dev/null | awk '{print $2}')
        if [ -n "$HS" ] && [ "$HS" -gt 0 ]; then
            AWG_HS_AGE=$(( $(date +%s) - HS ))
        fi

        # Wi-Fi: на «голых» x86 / mini-PC и роутерах с неподдерживаемым
        # wifi-чипом /etc/config/wireless либо отсутствует, либо пуст
        # (нет wifi-device секций). Это валидный кейс — UI должен показать
        # «нет беспроводного интерфейса», а не «(не задан)».
        WIRELESS_PRESENT="false"
        if [ -f /etc/config/wireless ] && uci -q show wireless 2>/dev/null | grep -q '=wifi-device'; then
            WIRELESS_PRESENT="true"
        fi
        SSID_RAW=$(uci -q get wireless.default_radio0.ssid || echo "")
        SSID=$(json_escape "$SSID_RAW")
        MODE_ESC=$(json_escape "$MODE")

        # Текущий тир Hagezi из adblock-lean config.
        # head -1 на raw_block_lists, потом срезаем NSFW-URL семейного фильтра
        # (если он там есть) — иначе он попадает в строку «Тир блок-листа» в UI.
        # Сам тир это первый whitespace-токен, не содержащий '/' (URL'ы содержат).
        TIER_LINE=$(grep -E '^raw_block_lists=' "$ETC_ADBLOCK_CFG" 2>/dev/null \
            | head -1 \
            | sed -e 's/^raw_block_lists="\?//' -e 's/"\?$//')
        TIER_RAW=$(printf '%s\n' "$TIER_LINE" | awk '{
            for (i = 1; i <= NF; i++) if (index($i, "/") == 0) { sub("^hagezi:", "", $i); print $i; exit }
        }')
        TIER=$(json_escape "${TIER_RAW:-pro}")

        # Семейный фильтр: family_filter_status печатает true / false.
        FAMILY_FILTER_ENABLED=$(family_filter_status)

        # Признак pre-install режима: токен на месте — значит ждём install_start
        TOKEN_PRESENT="false"
        [ -s "$ETC_CHEBURNET/install-token" ] && TOKEN_PRESENT="true"

        cat <<EOF
{
    "install_type": "$INSTALL_TYPE",
    "installing": $INSTALLING,
    "install_token_required": $TOKEN_PRESENT,
    "mode": "$MODE_ESC",
    "wireless_present": $WIRELESS_PRESENT,
    "ssid": "$SSID",
    "adblock_up": $ADBLOCK_UP,
    "podkop_up": $PODKOP_UP,
    "dns_up": $DNS_UP,
    "awg_handshake_age": $AWG_HS_AGE,
    "blocklist_tier": "$TIER",
    "family_filter_enabled": $FAMILY_FILTER_ENABLED
}
EOF
        ;;

    # ------------------------------------------------------------------
    install_start)
        # Проверяем, не идёт ли уже установка
        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo '{"error": "installation already running", "pid": '"$(cat "$PID_FILE")"'}'
            exit 0
        fi

        # === Проверка install-токена ===
        # Защита от LAN-сквоттинга: даже unauth-вызов должен предъявить токен,
        # выданный bootstrap.sh в /etc/cheburnet/install-token. После успешной
        # установки setup/install.sh удаляет файл — повторно установить нельзя
        # без нового bootstrap-запуска.
        TOKEN_FILE="$ETC_CHEBURNET/install-token"
        if [ ! -s "$TOKEN_FILE" ]; then
            echo '{"error": "install token not found — router is already installed or bootstrap.sh did not run. Re-run bootstrap.sh via SSH to get a new token."}'
            exit 0
        fi
        EXPECTED_TOKEN=$(cat "$TOKEN_FILE")
        GIVEN_TOKEN=$(jf '@.token')
        if [ -z "$GIVEN_TOKEN" ] || [ "$GIVEN_TOKEN" != "$EXPECTED_TOKEN" ]; then
            echo '{"error": "invalid install token — see SSH output of bootstrap.sh"}'
            exit 0
        fi

        SSID=$(jf '@.ssid')
        WIFI_KEY=$(jf '@.wifi_key')
        COUNTRY=$(jf '@.country')
        AWG_CONF=$(jf '@.awg_conf')
        ROOT_PASS=$(jf '@.root_pass')

        # Валидация
        [ -z "$SSID" ]     && { echo '{"error": "ssid required"}'; exit 0; }
        [ -z "$WIFI_KEY" ] && { echo '{"error": "wifi_key required"}'; exit 0; }
        [ "${#WIFI_KEY}" -lt 8 ] && { echo '{"error": "wifi_key must be >= 8 chars"}'; exit 0; }
        [ -z "$COUNTRY" ]  && COUNTRY="RU"
        [ -z "$ROOT_PASS" ] && { echo '{"error": "root_pass required"}'; exit 0; }
        [ "${#ROOT_PASS}" -lt 8 ] && { echo '{"error": "root_pass must be >= 8 chars"}'; exit 0; }

        [ -z "$AWG_CONF" ] && { echo '{"error": "awg_conf required"}'; exit 0; }

        # Сохраняем .conf во временный файл для валидации, потом — в финальное
        # место. Нормализуем CRLF → LF (юзер мог вставить .conf из Windows
        # Notepad) — висячий \r ломает не только наш парсер, но и сам awg-quick,
        # который читает этот файл напрямую при `awg-quick up awg0`.
        TMP_AWG="$STATE_DIR/awg0.conf.candidate"
        printf '%s\n' "$AWG_CONF" | tr -d '\r' > "$TMP_AWG"
        chmod 600 "$TMP_AWG"
        # Полная валидация: [Interface]/PrivateKey/[Peer]/PublicKey/Endpoint.
        # Без проверки PublicKey/Endpoint в обоих entry-point'ах обрезанный
        # конфиг проходил сюда, потом 01-amneziawg.sh скачивал ~3 МБ kmod-
        # пакетов и падал через 30 сек с непонятным "ERROR: .conf parse failed".
        if ! AWG_ERR=$(awg_validate_conf "$TMP_AWG"); then
            rm -f "$TMP_AWG"
            ESC=$(json_escape "$AWG_ERR")
            echo "{\"error\": \"awg_conf is missing: $ESC\"}"
            exit 0
        fi
        mkdir -p "$ETC_AWG_DIR"
        mv "$TMP_AWG" "$ETC_AWG_DIR/awg0.conf"
        chmod 600 "$ETC_AWG_DIR/awg0.conf"

        # Передаём root-пароль setup/install.sh через короткоживущий файл (chmod 600)
        umask 077
        printf '%s' "$ROOT_PASS" > "$STATE_DIR/root_pass"
        chmod 600 "$STATE_DIR/root_pass"
        unset ROOT_PASS

        # Сохраняем Wi-Fi-параметры для 05-wifi.sh
        cat > "$INSTALL_DIR/configs/wireless-actual.txt" <<EOF
WIFI_SSID="$SSID"
WIFI_KEY="$WIFI_KEY"
WIFI_COUNTRY="$COUNTRY"
EOF
        chmod 600 "$INSTALL_DIR/configs/wireless-actual.txt"

        # Чистим старые артефакты
        rm -f "$DONE_FILE" "$LOG_FILE" "$STATE_FILE"
        echo "starting" > "$STATE_FILE"

        # setsid создаёт новую process-group (PGID=PID), чтобы install_cancel
        # мог убить весь дочерний дерево через kill -- -PID.
        # nohup НЕ используем — на минимальной OpenWrt 25.12 его в PATH нет.
        # setsid + явный </dev/null уже отвязывают от controlling terminal,
        # поэтому SIGHUP из rpcd-сессии до потомка не доходит.
        setsid "$INSTALL_DIR/setup/install.sh" \
            > "$LOG_FILE" 2>&1 < /dev/null &
        PID=$!
        echo "$PID" > "$PID_FILE"

        echo "{\"status\": \"started\", \"pid\": $PID}"
        ;;

    # ------------------------------------------------------------------
    install_progress)
        # Текущий шаг
        STEP_RAW=$(cat "$STATE_FILE" 2>/dev/null || echo "idle")
        STEP=$(json_escape "$STEP_RAW")

        # Процесс жив?
        RUNNING="false"
        if [ -f "$PID_FILE" ]; then
            kill -0 "$(cat "$PID_FILE")" 2>/dev/null && RUNNING="true"
        fi

        # Установка завершилась?
        DONE="false"
        RESULT="unknown"
        if [ -f "$DONE_FILE" ]; then
            DONE="true"
            RESULT=$(json_escape "$(cat "$DONE_FILE")")
        elif [ "$RUNNING" = "false" ] && [ -f "$LOG_FILE" ]; then
            # Процесс уже не живой, но done-маркер не записан →
            # orchestrator упал/был убит. Сообщаем UI как ошибку.
            DONE="true"
            RESULT="crashed"
        fi

        # Последние 12000 байт лога с JSON-escape.
        # 12 КБ ≈ 150 строк × 80 символов — гарантирует, что строка
        # «✗ ШАГ X завершился с ошибкой» и контекст ошибки от самого шага
        # остаются в видимом окне даже когда после них дописан runtime-снимок
        # и step-specific диагностика. Меньше — выталкивает причину; больше —
        # бессмысленно (фронт всё равно ограничивает CSS max-height).
        LOG_RAW=$(tail -c 12000 "$LOG_FILE" 2>/dev/null || echo "")
        LOG=$(json_escape "$LOG_RAW")

        cat <<EOF
{
    "step": "$STEP",
    "running": $RUNNING,
    "done": $DONE,
    "result": "$RESULT",
    "log": "$LOG"
}
EOF
        ;;

    # ------------------------------------------------------------------
    install_cancel)
        if [ -f "$PID_FILE" ]; then
            PID=$(cat "$PID_FILE")
            kill "$PID" 2>/dev/null || true
            # kill всей process-группы (в fork'ах могут висеть apk/wget)
            kill -- -"$PID" 2>/dev/null || true
            echo "cancelled" > "$DONE_FILE"
            echo '{"status": "cancelled"}'
        else
            echo '{"status": "not_running"}'
        fi
        ;;

    # ------------------------------------------------------------------
    mode_switch)
        NEW_MODE=$(jf '@.mode')
        if ! cheburnet_valid_mode "$NEW_MODE"; then
            echo '{"error": "mode must be home or travel"}'; exit 0
        fi

        if [ ! -x "$USR_BIN_VPN_MODE" ]; then
            echo '{"error": "vpn-mode CLI not installed — установите VPN-режим"}'
            exit 0
        fi

        OUT=$("$USR_BIN_VPN_MODE" "$NEW_MODE" 2>&1) || {
            echo "{\"error\": \"vpn-mode $NEW_MODE failed\", \"output\": \"$(echo "$OUT" | tr '\n' ' ')\"}"
            exit 0
        }
        echo "{\"status\": \"ok\", \"mode\": \"$NEW_MODE\"}"
        ;;

    # ------------------------------------------------------------------
    service_restart)
        SVC=$(jf '@.service')
        case "$SVC" in
            vpn)
                # Полный рестарт VPN-стека
                ifdown awg0 2>/dev/null; sleep 1; ifup awg0 2>/dev/null
                "$ETC_INIT_D/podkop" restart >/dev/null 2>&1 &
                echo '{"status": "vpn restarting"}'
                ;;
            dns)
                "$ETC_INIT_D/dnsmasq" restart >/dev/null 2>&1
                echo '{"status": "dns restarted"}'
                ;;
            adblock)
                "$ETC_INIT_D/adblock-lean" start >/dev/null 2>&1
                "$ETC_INIT_D/dnsmasq" restart >/dev/null 2>&1
                echo '{"status": "adblock reloaded"}'
                ;;
            *)
                echo '{"error": "unknown service"}'
                ;;
        esac
        ;;

    # ------------------------------------------------------------------
    set_blocklist_tier)
        TIER=$(jf '@.tier')
        if ! cheburnet_valid_tier "$TIER"; then
            echo '{"error": "tier must be one of: light, normal, pro, pro.plus, ultimate, tif, tif.medium, tif.mini, multi.pro, fake"}'; exit 0
        fi

        if [ ! -f "$ETC_ADBLOCK_CFG" ]; then
            echo '{"error": "adblock-lean config not found — установка не завершена"}'; exit 0
        fi

        # Заменяем строку raw_block_lists=... в конфиге
        sed -i "s|^raw_block_lists=.*|raw_block_lists=\"hagezi:${TIER}\"|" "$ETC_ADBLOCK_CFG"

        _reload_blocklist &

        TIER_ESC=$(json_escape "$TIER")
        echo "{\"status\": \"tier set\", \"tier\": \"$TIER_ESC\"}"
        ;;

    # ------------------------------------------------------------------
    set_family_filter)
        ENABLED=$(jf '@.enabled')
        case "$ENABLED" in
            true|false) ;;
            *) echo '{"error": "enabled must be true or false"}'; exit 0 ;;
        esac

        if [ ! -f "$ETC_ADBLOCK_CFG" ]; then
            echo '{"error": "adblock-lean config not found — установка не завершена"}'; exit 0
        fi

        if [ "$ENABLED" = "true" ]; then
            family_filter_on || { echo '{"error": "не удалось обновить /etc/adblock-lean/config"}'; exit 0; }
        else
            family_filter_off || { echo '{"error": "не удалось обновить /etc/adblock-lean/config"}'; exit 0; }
        fi

        _reload_blocklist &

        echo "{\"status\": \"family_filter set\", \"enabled\": $ENABLED}"
        ;;

    # ------------------------------------------------------------------
    factory_reset)
        # Защита от случайного срабатывания: confirm должен быть строго "RESET"
        CONFIRM=$(jf '@.confirm')
        if ! cheburnet_valid_factory_confirm "$CONFIRM"; then
            echo '{"error": "confirm must be exactly \"RESET\""}'; exit 0
        fi

        # Запускаем firstboot отложенно (~3 сек), чтобы успеть отдать RPC-ответ
        # и закрыть сессию. /etc/init.d/done вызывает sysupgrade -r.
        ( sleep 3 && firstboot -y && reboot ) >/dev/null 2>&1 &
        echo '{"status": "factory reset scheduled, router will reboot in ~5 seconds"}'
        ;;

    # ------------------------------------------------------------------
    replace_awg_conf)
        # Замена awg0.conf после установки. UI этим методом обновляет ключи
        # когда сервер заблокирован/тормозит. Защитный пояс из 4 шагов:
        #   1) pre-flight: VPN уже установлен (иначе менять нечего);
        #   2) валидация — та же awg_validate_conf, что в install_start
        #      (entry-point ловит обрезанный conf ДО ~3 МБ apk-загрузок);
        #   3) backup .prev + atomic mv нового conf;
        #   4) фоновый apply через 01-amneziawg.sh; при exit≠0 — auto-rollback
        #      на .prev и повторный apply, чтобы юзер не остался без VPN.
        # Прогресс читается через тот же install_progress (state="replacing-awg",
        # done="ok"|"fail-rolled-back"|"fail").

        if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo '{"error": "operation already running", "pid": '"$(cat "$PID_FILE")"'}'
            exit 0
        fi

        # Pre-flight: VPN должен быть уже установлен. До установки awg0.conf
        # ещё нет, и подkop init не существует — менять нечего. Соответствует
        # критерию "vpn" в get_status.install_type.
        if [ ! -f "$ETC_AWG_DIR/awg0.conf" ] || [ ! -x "$ETC_INIT_D/podkop" ]; then
            echo '{"error": "VPN не установлен — пройдите мастер заново"}'
            exit 0
        fi

        AWG_CONF=$(jf '@.awg_conf')
        [ -z "$AWG_CONF" ] && { echo '{"error": "awg_conf required"}'; exit 0; }

        # Валидация в candidate-файле, как в install_start. Нормализуем CRLF→LF
        # (юзер мог вставить .conf из Windows Notepad).
        TMP_AWG="$STATE_DIR/awg0.conf.candidate"
        printf '%s\n' "$AWG_CONF" | tr -d '\r' > "$TMP_AWG"
        chmod 600 "$TMP_AWG"
        if ! AWG_ERR=$(awg_validate_conf "$TMP_AWG"); then
            rm -f "$TMP_AWG"
            ESC=$(json_escape "$AWG_ERR")
            echo "{\"error\": \"awg_conf is missing: $ESC\"}"
            exit 0
        fi

        # Backup текущего conf для возможного rollback. .prev живёт до конца
        # apply-блока: при успехе удаляется (новый conf принят), при сбое —
        # возвращается на место. Один backup, без истории.
        BACKUP_FILE="$ETC_AWG_DIR/awg0.conf.prev"
        cp "$ETC_AWG_DIR/awg0.conf" "$BACKUP_FILE"
        chmod 600 "$BACKUP_FILE"

        # Atomic swap. mv в пределах одной FS — атомарен; awg-quick читать
        # промежуточное состояние не успеет.
        mv "$TMP_AWG" "$ETC_AWG_DIR/awg0.conf"
        chmod 600 "$ETC_AWG_DIR/awg0.conf"

        # Чистим артефакты предыдущего apply (install/replace), чтобы
        # install_progress видел СВЕЖИЙ STATE/DONE/LOG.
        rm -f "$DONE_FILE" "$LOG_FILE"
        echo "[STEP] replacing-awg" > "$STATE_FILE"

        # Apply-скрипт собираем в STATE_DIR. Heredoc с одинарной кавычкой
        # (<<'APPLY') — переменные внутри НЕ раскрываются на этапе записи;
        # пути приходят через env при запуске. Это устраняет shell-quoting-
        # ад «setsid sh -c '...'$VAR'...'» и делает тестируемым (можно
        # прочитать сгенерированный скрипт).
        APPLY_SCRIPT="$STATE_DIR/replace-apply.sh"
        cat > "$APPLY_SCRIPT" <<'APPLY'
#!/bin/sh
# Сгенерирован rpcd-cheburnet (replace_awg_conf). Применяет новый awg0.conf
# через 01-amneziawg.sh, при сбое возвращает старый и переподнимает.
set -u
if sh "$AMNEZIA_SCRIPT" > "$LOG_FILE" 2>&1; then
    rm -f "$BACKUP_FILE"
    printf 'ok\n' > "$DONE_FILE"
else
    if [ -f "$BACKUP_FILE" ]; then
        logger -t cheburnet-replace-awg "new awg0.conf failed; rolling back to previous"
        mv "$BACKUP_FILE" "$AWG_CONF_PATH"
        chmod 600 "$AWG_CONF_PATH"
        sh "$AMNEZIA_SCRIPT" >> "$LOG_FILE" 2>&1 || true
        printf 'fail-rolled-back\n' > "$DONE_FILE"
    else
        printf 'fail\n' > "$DONE_FILE"
    fi
fi
APPLY
        chmod +x "$APPLY_SCRIPT"

        # setsid отвязывает дочерний процесс от controlling terminal rpcd
        # (чтобы SIGHUP при выходе rpcd-сессии не убил apply-block до того,
        # как done-маркер запишется). Тот же приём, что в install_start.
        LOG_FILE="$LOG_FILE" \
        DONE_FILE="$DONE_FILE" \
        BACKUP_FILE="$BACKUP_FILE" \
        AWG_CONF_PATH="$ETC_AWG_DIR/awg0.conf" \
        AMNEZIA_SCRIPT="$INSTALL_DIR/setup/01-amneziawg.sh" \
        setsid sh "$APPLY_SCRIPT" < /dev/null >/dev/null 2>&1 &
        PID=$!
        echo "$PID" > "$PID_FILE"
        echo "{\"status\": \"applying\", \"pid\": $PID}"
        ;;

    # ------------------------------------------------------------------
    *)
        echo '{"error": "unknown method"}'
        ;;
esac
