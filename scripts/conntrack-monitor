#!/bin/sh
# conntrack-monitor — мониторинг заполненности таблицы conntrack.
#
# Запускается каждые 15 минут через cron. Логирует заполненность.
# При >80% — предупреждение. При >95% — принудительный сброс таблицы
# (conntrack -F), чтобы избежать полного переполнения и падения скорости VPN.
#
# Симптом переполнения: скорость VPN падает в 10–100 раз без потери связи.
# Лечение вручную: conntrack -F && logread -e conntrack

max=$(cat /proc/sys/net/netfilter/nf_conntrack_max)
cur=$(cat /proc/sys/net/netfilter/nf_conntrack_count)
pct=$(( cur * 100 / max ))

if [ "$pct" -ge 95 ]; then
    logger -t conntrack-monitor "CRITICAL: ${cur}/${max} (${pct}%) — flush"
    conntrack -F 2>/dev/null || true
elif [ "$pct" -ge 80 ]; then
    logger -t conntrack-monitor "WARN: ${cur}/${max} (${pct}%) — high, check traffic"
fi
# При <80% не логируем — это норма. Текущие значения всегда доступны через
#   cat /proc/sys/net/netfilter/nf_conntrack_count
#   cat /proc/sys/net/netfilter/nf_conntrack_max
# Раньше тут писалось "OK: ..." каждые 15 минут (96 строк/день) — это
# забивало logd ring-buffer и log-snapshot реальными инцидентами.
