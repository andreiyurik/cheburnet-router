#!/bin/sh
# vpn-mode — переключение режима маршрутизации.
#
# HOME   — .ru/.su/.рф напрямую, остальное через VPN
# TRAVEL — весь трафик через VPN
#
# Состояние хранится в UCI podkop'а (persistent через sysupgrade), отдельного
# state-файла нет: HOME = community_lists в exclude_ru, TRAVEL = очищено.
# UCI-логика — в lib/podkop-config.sh (общая со setup/02-podkop.sh).
#
# Usage: vpn-mode {home|travel|status}

log() { logger -t vpn-mode "$*"; }

reload_podkop() {
    /etc/init.d/podkop reload >/dev/null 2>&1 &
}

LIB_DIR="${CHEBURNET_LIB_DIR:-/opt/cheburnet/lib}"
[ -f "$LIB_DIR/podkop-config.sh" ] || LIB_DIR="$(dirname "$0")/../lib"
# shellcheck source=../lib/podkop-config.sh disable=SC1090,SC1091
. "$LIB_DIR/podkop-config.sh"

current_mode() {
    if [ -n "$(uci -q get podkop.exclude_ru.community_lists)" ]; then
        echo home
    else
        echo travel
    fi
}

case "$1" in
    home)
        [ "$(current_mode)" = home ] && exit 0
        podkop_apply_home
        log "mode=HOME applied (VPN for all except RU)"
        reload_podkop ;;
    travel)
        [ "$(current_mode)" = travel ] && exit 0
        podkop_apply_travel
        log "mode=TRAVEL applied (full tunnel)"
        reload_podkop ;;
    status)
        echo "Режим:   $(current_mode)"
        echo "Домены:  $(uci -q get podkop.exclude_ru.community_lists || echo '(пусто)')"
        echo "Домены+: $(uci -q get podkop.exclude_ru.user_domains || echo '(пусто)')" ;;
    *)
        echo "Usage: $0 {home|travel|status}" >&2
        exit 1 ;;
esac
