#!/bin/sh
# dns-healthcheck — failover Quad9 ↔ Cloudflare при сбоях DNS.
#
# Запуск каждые 5 мин через cron. Если 3 раза подряд DNS не работает —
# переключаем провайдера через /usr/bin/dns-provider. Когда на fallback
# (Cloudflare) — раз в час пробуем вернуться на Quad9.

STATE_DIR=/tmp/dns-health
mkdir -p "$STATE_DIR"
FAIL_FILE="$STATE_DIR/fails"
LAST_RETRY_FILE="$STATE_DIR/last-retry"
MAX_FAILS=3
RETRY_BACK_SECONDS=3600
PROBE_TIMEOUT=3

log() { logger -t dns-health "$*"; }

# Пробит резолв cloudflare.com через указанный server (по умолчанию — локальный
# dnsmasq, который ходит через текущий DoH). probe 9.9.9.9 — прямая проверка
# Quad9 перед возвратом на него с fallback'а.
probe() {
    nslookup -timeout="$PROBE_TIMEOUT" cloudflare.com "${1:-127.0.0.1}" 2>/dev/null \
        | grep -qE "Address.*[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+"
}

current_provider() {
    case "$(uci -q get podkop.settings.dns_server)" in
        dns.quad9.net/dns-query)      echo quad9 ;;
        cloudflare-dns.com/dns-query) echo cloudflare ;;
        *)                            echo other ;;
    esac
}

get_fails() { cat "$FAIL_FILE" 2>/dev/null || echo 0; }
set_fails() { echo "$1" > "$FAIL_FILE"; }

if probe; then
    set_fails 0
    # Здоровый локальный DNS. Если сидим на fallback Cloudflare — раз в час
    # пробуем вернуться на Quad9.
    if [ "$(current_provider)" = "cloudflare" ]; then
        now=$(date +%s)
        last_retry=$(cat "$LAST_RETRY_FILE" 2>/dev/null || echo 0)
        if [ $((now - last_retry)) -ge $RETRY_BACK_SECONDS ]; then
            echo "$now" > "$LAST_RETRY_FILE"
            if probe 9.9.9.9; then
                log "Quad9 reachable again, restoring as primary"
                /usr/bin/dns-provider quad9
            else
                log "Quad9 still unreachable, staying on Cloudflare"
            fi
        fi
    fi
    exit 0
fi

# Probe failed — копим до MAX_FAILS перед swap'ом
fails=$(( $(get_fails) + 1 ))
set_fails "$fails"
[ "$fails" -lt "$MAX_FAILS" ] && exit 0

case "$(current_provider)" in
    quad9)
        log "Quad9 DNS failed ${fails}x, failover to Cloudflare"
        /usr/bin/dns-provider cloudflare
        set_fails 0
        date +%s > "$LAST_RETRY_FILE"
        ;;
    cloudflare)
        log "Cloudflare DNS failed ${fails}x, trying Quad9 again"
        /usr/bin/dns-provider quad9
        set_fails 0
        ;;
esac
